rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Flow sessions (legacy)
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // User items (flow, journal, memo, research, deepdive)
    match /users/{userId}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Research Projects
    match /users/{userId}/projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Workspace metadata (single doc per user)
    match /users/{userId}/workspace/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge Graph — Entity Nodes
    match /users/{userId}/kg_nodes/{nodeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge Graph — Relationship Edges
    match /users/{userId}/kg_edges/{edgeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge Processing Jobs
    match /users/{userId}/processing/{jobId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Unified Knowledge Sources Registry
    match /users/{userId}/knowledge_sources/{sourceId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

